# 全港學校 AI 教育需求雷達系統 - 環境變量配置
# 複製此文件為 .env.local 並填入實際值

# ===========================================
# 數據庫配置 (選擇以下其中一種)
# ===========================================

# PostgreSQL 直接連接
DATABASE_URL=postgresql://username:password@localhost:5432/school_ai_radar

# Supabase (推薦)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# AI 服務配置
# ===========================================

# OpenAI API (用於智能分析)
OPENAI_API_KEY=sk-your-openai-api-key

# 或使用其他 AI 服務
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ===========================================
# 網站抓取配置
# ===========================================

# 抓取代理設置 (可選)
SCRAPING_PROXY_URL=
SCRAPING_API_KEY=

# 請求限制
SCRAPING_RATE_LIMIT=10
SCRAPING_TIMEOUT=30000

# ===========================================
# 應用配置
# ===========================================

# 應用 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 認證密鑰 (生產環境必須更改)
AUTH_SECRET=your-super-secret-key-change-in-production

# ===========================================
# 第三方服務 (可選)
# ===========================================

# 郵件服務
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# 分析服務
NEXT_PUBLIC_ANALYTICS_ID=
