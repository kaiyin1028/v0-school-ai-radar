# ===========================================
# 全港學校 AI 教育需求雷達系統
# 環境變量配置文件
# ===========================================
# 複製此文件為 .env.local 並填入實際值
# cp .env.example .env.local

# ===========================================
# Mock 模式切換 (開發環境設為 true)
# ===========================================
NEXT_PUBLIC_USE_MOCKS=true

# ===========================================
# API 配置
# ===========================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_API_TIMEOUT=30000

# ===========================================
# 數據庫配置 (生產環境)
# ===========================================

# PostgreSQL 連接字符串
DATABASE_URL=postgresql://username:password@localhost:5432/school_ai_radar

# Supabase (推薦方案)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Neon (備選方案)
# DATABASE_URL=postgres://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb

# ===========================================
# 認證配置
# ===========================================

# JWT 密鑰 (生產環境必須更改)
AUTH_SECRET=your-super-secret-key-change-in-production-min-32-chars

# Session 配置
SESSION_COOKIE_NAME=school_ai_radar_session
SESSION_MAX_AGE=604800

# ===========================================
# AI 服務配置
# ===========================================

# OpenAI (用於智能分析和推薦)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# 備選 AI 服務
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ===========================================
# 網站抓取配置
# ===========================================

# 抓取代理 (用於繞過 IP 限制)
SCRAPING_PROXY_URL=
SCRAPING_PROXY_USERNAME=
SCRAPING_PROXY_PASSWORD=

# 抓取 API 服務 (如 ScrapingBee, Crawlbase)
SCRAPING_API_KEY=
SCRAPING_API_URL=

# 抓取限制
SCRAPING_RATE_LIMIT=10
SCRAPING_TIMEOUT=30000
SCRAPING_MAX_PAGES_PER_SCHOOL=100
SCRAPING_CONCURRENT_JOBS=3

# ===========================================
# 應用配置
# ===========================================

# 應用 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 環境標識
NODE_ENV=development

# ===========================================
# 郵件服務 (可選)
# ===========================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ===========================================
# 日誌和監控 (可選)
# ===========================================

# Sentry (錯誤監控)
SENTRY_DSN=

# 分析服務
NEXT_PUBLIC_ANALYTICS_ID=

# 日誌級別 (debug, info, warn, error)
LOG_LEVEL=info

# ===========================================
# 文件存儲 (可選)
# ===========================================

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-southeast-1
